# ── Backend › Development Image ─────────────────────────────────────────────
# Hot-reload enabled via uvicorn --reload.
# Source code is bind-mounted from the host (see docker-compose.dev.yml) so
# every file save instantly reflects inside the container — no rebuild needed.
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.12-slim

# Keeps Python output unbuffered (great for docker logs)
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# Install system-level build dependencies (for packages that compile C extensions)
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies first (cached layer — only re-runs when requirements change)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# Copy the application source (overridden by the bind-mount in dev, but useful for
# standalone `docker build` runs)
COPY . .

# FastAPI dev server — reload watches the /app directory
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
