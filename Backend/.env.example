CLASSIFIER_MAX_TOKENS=400
GENERATION_MAX_TOKENS=1200

FIRECRAWL_SEARCH_LIMIT=3
MAX_TEXT_CHARS=3500
TEXT_CHUNK_OVERLAP=400
PDF_PAGES_PER_CHUNK=6
INLINE_MEDIA_LIMIT_BYTES=20000000
GENERATED_PRESENTATIONS_DIR=generated_presentations
